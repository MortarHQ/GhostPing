{
  "name": "ghostping",
  "version": "0.0.4",
  "private": false,
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "start": "pnpm run start:build && pnpm run start:check-update && pnpm run start:server",
    "start:build": "pnpm run web:build",
    "start:check-update": "tsx scripts/check-version-update.ts",
    "start:server": "tsx src/appServer.ts --env production",
    "dev": "tsx watch --clear-screen=false --exclude data/offset.fn.js src/appServer.ts --env development",
    "web:dev": "vite --config frontend/vite.config.ts",
    "web:build": "vite build --config frontend/vite.config.ts",
    "web:preview": "vite preview --config frontend/vite.config.ts",
    "mc:ping": "tsx src/mcClient.ts --env test",
    "test": "pnpm run mc:ping",
    "protocols:update": "tsx scripts/update-protocols.ts",
    "release:manifest": "tsx .github/scripts/generate-version-manifest.ts",
    "release:manifest:check": "tsx .github/scripts/generate-version-manifest.ts --check"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.19",
    "js-beautify": "^1.15.4",
    "lucide-react": "^0.542.0",
    "monaco-editor": "^0.52.2",
    "pino": "^10.3.0",
    "pino-pretty": "^13.1.3",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "tailwind-merge": "^3.3.1",
    "toml": "^3.0.0",
    "tw-animate-css": "^1.4.0",
    "varint": "^6.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.13",
    "@types/js-beautify": "^1.14.3",
    "@types/node": "^25.2.0",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "@types/varint": "^6.0.3",
    "@vitejs/plugin-react": "^5.0.1",
    "tailwindcss": "^4.1.13",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.1.5"
  }
}
